# Backend
# Local dev:
DATABASE_URL=sqlite:///./lead_engine.db
# Railway with a mounted volume at /data:
# DATABASE_URL=sqlite:////data/lead_engine.db
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-image-preview
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=factory@example.com
SMTP_USE_TLS=true
SMTP_MOCK_MODE=true
OUTREACH_DISPATCH_INTERVAL_SEC=300
OUTREACH_LOG_FILE=./outreach_emails.log

# Frontend
# Local dev:
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8010
# Vercel production example:
# NEXT_PUBLIC_BACKEND_URL=https://your-api.up.railway.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
